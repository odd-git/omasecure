#!/usr/bin/env bash
set -euo pipefail

for cmd in rofi notify-send ssh rsync; do
  command -v "$cmd" &>/dev/null || { notify-send -u critical "omasync-setup" "$cmd not found"; exit 1; }
done

OMABIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$OMABIN:/home/linuxbrew/.linuxbrew/bin:$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

CFG="${XDG_CONFIG_HOME:-$HOME/.config}/omablue/omasync"
SSH_DIR="$HOME/.ssh"
mkdir -p "$CFG/devices" "$CFG/profiles" "$SSH_DIR"
chmod 700 "$SSH_DIR"

# Source lib for discovery functions
# shellcheck disable=SC1090
source "$OMABIN/omasync-lib.sh"

T="-theme my_theme.rasi"

menu()  { printf '%s\n' "$@" | rofi -dmenu -i -p "${TITLE:-Menu}" $T || true; }
input() {
  local label="$1" default="${2:-}" description="${3:-}"
  # Show instructions directly in rofi message bar
  if [[ -n "$description" ]]; then
    printf '%s\n' "$default" | rofi -dmenu -p "$label:" -filter "$default" -mesg "$description" $T || true
  else
    printf '%s\n' "$default" | rofi -dmenu -p "$label:" -filter "$default" $T || true
  fi
}
ask()   { [[ "$(printf 'Yes\nNo\n' | rofi -dmenu -p "$1" $T || true)" == "Yes" ]]; }
note()  { notify-send -a "omasync" "$1" "${2:-}"; }
err()   { notify-send -a "omasync" -u critical "$1" "${2:-}"; }

slug()  { echo "$1" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-_'; }
clean_hostname() { echo "$1" | tr -d ' ' | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9.-'; }

deploy_ssh_key_interactive() {
  local key="$1" user="$2" host="$3" port="$4" device_name="$5"
  local TERMINAL="foot"
  local TUI_CLASS="omablue-floating"

  nohup "$TERMINAL" \
    --app-id="$TUI_CLASS" \
    --title="Deploy SSH Key to $device_name" \
    /bin/bash -l -c "ssh-copy-id -i '$key.pub' -p '$port' '$user@$host' && sleep 2 && echo 'Key deployed successfully!' && read -rp 'Press Enter to close...' || { echo 'Key deployment failed.'; read -rp 'Press Enter to close...'; }" \
    >/dev/null 2>&1 &

  sleep 1
  note "Deploying SSH key" "Enter your password when prompted"
}

# ── DEVICES ────────────────────────────────────────────────────────────────────

add_device() {
  local name host port user dtype ts key id
  local source_mode

  source_mode=$(printf 'Discover\nManual entry\n' | rofi -dmenu -p "Add device:" $T) || return 0
  [[ -z "$source_mode" ]] && return 0

  if [[ "$source_mode" == "Discover" ]]; then
    discover_and_add_device
  else
    manual_add_device
  fi
}

discover_and_add_device() {
  local -a entries=()
  local -a labels=()

  # Tailscale peers (prioritized)
  if is_tailscale_available; then
    while IFS=$'\t' read -r hostname ip os; do
      entries+=("TS|$hostname|$ip|$os|true")
      labels+=("  TS  $hostname  ($ip)  [$os]")
    done < <(scan_tailscale_peers 2>/dev/null)
  fi

  # LAN hosts
  while IFS=$'\t' read -r ip port; do
    entries+=("LAN|$ip|$ip|unknown|false")
    labels+=(" LAN  $ip:$port")
  done < <(scan_lan_hosts 2>/dev/null)

  if [[ ${#entries[@]} -eq 0 ]]; then
    err "No devices found" "Check network connection or use Manual entry"
    return 0
  fi

  local selected
  selected=$(printf '%s\n' "${labels[@]}" | rofi -dmenu -p "Select device:" $T) || return 0
  [[ -z "$selected" ]] && return 0

  local idx=-1
  for i in "${!labels[@]}"; do
    [[ "${labels[$i]}" == "$selected" ]] && idx=$i && break
  done
  [[ $idx -lt 0 ]] && return 0

  local source hostname ip os ts
  IFS='|' read -r source hostname ip os ts <<< "${entries[$idx]}"

  local name user port dtype host_for_config
  # For LAN devices, use IP directly; for Tailscale, sanitize hostname to remove invalid chars
  host_for_config="$ip"
  [[ "$source" == "TS" ]] && host_for_config="$(clean_hostname "$hostname")"

  name=$(input "Device name" "$hostname" "Short name for this device (e.g. pixel9, thinkpad)") || return 0
  [[ -z "$name" ]] && return 0
  id=$(slug "$name")

  user=$(input "SSH username" "" "User account on the remote device (e.g. root for Linux, u0_a276 for Termux)") || return 0
  [[ -z "$user" ]] && return 0

  if [[ "$source" == "LAN" ]]; then
    # For LAN, we already know the port from port probe
    local probe_port=22
    while IFS=$'\t' read -r p_ip p_port; do
      if [[ "$p_ip" == "$ip" ]]; then probe_port=$p_port; break; fi
    done < <(scan_lan_hosts 2>/dev/null)
    port=$(input "SSH port" "$probe_port" "Port number where SSH runs (22 for Linux/macOS, 8022 for Termux)") || return 0
    [[ -z "$port" ]] && port=22
    ts="false"
  else
    # Tailscale - default to 22, allow override
    port=$(input "SSH port" "22" "Port number where SSH runs (usually 22)") || return 0
    [[ -z "$port" ]] && port=22
    ts="true"
  fi

  dtype=$(printf 'linux\ntermux\nmacos\n' | rofi -dmenu -p "Device type" -mesg "What OS is this device running?" $T) || return 0
  [[ -z "$dtype" ]] && return 0

  key="$SSH_DIR/omasync_${id}"
  key_existed=false
  if [[ ! -f "$key" ]]; then
    ssh-keygen -t ed25519 -f "$key" -N "" -C "omasync@${id}" -q
    chmod 600 "$key"; chmod 644 "${key}.pub"
  else
    key_existed=true
  fi

  local pub; pub=$(<"${key}.pub")
  command -v wl-copy &>/dev/null && printf '%s' "$pub" | wl-copy || true

  if ask "Deploy SSH key to $name now?"; then
    deploy_ssh_key_interactive "$key" "$user" "$ip" "$port" "$name"
  else
    local guide
    case "$dtype" in
      termux) guide="1. pkg install openssh\n2. mkdir -p ~/.ssh\n3. Paste key in ~/.ssh/authorized_keys\n4. chmod 600 ~/.ssh/authorized_keys\n5. sshd  (port 8022 by default)\n\n$pub" ;;
      *)      guide="ssh-copy-id -i ${key}.pub -p ${port} ${user}@${ip}\n\nOr paste manually into ~/.ssh/authorized_keys\n\n$pub" ;;
    esac
    printf 'OK\n' | rofi -dmenu -p "Setup guide — press Enter to continue" -mesg "$guide" $T || true
  fi

  cat > "$CFG/devices/${id}.conf" <<EOF
DEVICE_NAME="$name"
DEVICE_HOST="$host_for_config"
DEVICE_PORT="$port"
DEVICE_USER="$user"
DEVICE_KEY="$key"
DEVICE_TYPE="$dtype"
DEVICE_TAILSCALE="$ts"
EOF
  note "Device saved" "$name → $host_for_config:$port"

  if ask "Test connection to $name now?"; then
    local opts=(-o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=accept-new -p "$port")
    [[ -f "$key" ]] && opts+=(-i "$key")
    if ssh "${opts[@]}" "${user}@${ip}" exit 2>/dev/null; then
      note "Connection OK" "$name is reachable"
    else
      err "Connection failed" "Check: device online? sshd running? key installed?"
    fi
  fi

  if ask "Deploy SSH key to $name now?"; then
    deploy_ssh_key_interactive "$key" "$user" "$ip" "$port" "$name"
  fi

  if ask "Add sync profiles for $name now?"; then
    while true; do
      add_device_profile "$id" || break
      ask "Add another profile?" || break
    done
  fi
}

manual_add_device() {
  local name host port user dtype ts key

  name=$(input "Device name" "" "Short name for this device (e.g. pixel9, thinkpad)") || return 0
  [[ -z "$name" ]] && return 0
  local id; id=$(slug "$name")

  host=$(input "Host or IP" "" "IP address (192.168.1.50) or hostname (for Tailscale, use the device hostname)") || return 0
  [[ -z "$host" ]] && return 0

  port=$(input "SSH port" "22" "Port number where SSH runs (22 for Linux/macOS, 8022 for Termux)") || return 0
  [[ -z "$port" ]] && port=22

  user=$(input "SSH username" "" "User account on the remote device (e.g. root for Linux, u0_a276 for Termux)") || return 0
  [[ -z "$user" ]] && return 0

  dtype=$(printf 'linux\ntermux\nmacos\n' | rofi -dmenu -p "Device type" -mesg "What OS is this device running?" $T) || return 0
  [[ -z "$dtype" ]] && return 0

  ts=false; ask "Use Tailscale for this device? (only if device is on your Tailscale network)" && ts=true || true

  key="$SSH_DIR/omasync_${id}"
  if [[ ! -f "$key" ]]; then
    ssh-keygen -t ed25519 -f "$key" -N "" -C "omasync@${id}" -q
    chmod 600 "$key"; chmod 644 "${key}.pub"
  fi

  local pub; pub=$(<"${key}.pub")
  command -v wl-copy &>/dev/null && printf '%s' "$pub" | wl-copy || true

  if ask "Deploy SSH key to $name now?"; then
    deploy_ssh_key_interactive "$key" "$user" "$host" "$port" "$name"
  else
    local guide
    case "$dtype" in
      termux) guide="1. pkg install openssh\n2. mkdir -p ~/.ssh\n3. Paste key in ~/.ssh/authorized_keys\n4. chmod 600 ~/.ssh/authorized_keys\n5. sshd  (port 8022 by default)\n\n$pub" ;;
      *)      guide="ssh-copy-id -i ${key}.pub -p ${port} ${user}@${host}\n\nOr paste manually into ~/.ssh/authorized_keys\n\n$pub" ;;
    esac
    printf 'OK\n' | rofi -dmenu -p "Setup guide — press Enter to continue" -mesg "$guide" $T || true
  fi

  cat > "$CFG/devices/${id}.conf" <<EOF
DEVICE_NAME="$name"
DEVICE_HOST="$host"
DEVICE_PORT="$port"
DEVICE_USER="$user"
DEVICE_KEY="$key"
DEVICE_TYPE="$dtype"
DEVICE_TAILSCALE="$ts"
EOF
  note "Device saved" "$name → $host:$port"

  if ask "Test connection to $name now?"; then
    local opts=(-o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=accept-new -p "$port")
    [[ -f "$key" ]] && opts+=(-i "$key")
    if ssh "${opts[@]}" "${user}@${host}" exit 2>/dev/null; then
      note "Connection OK" "$name is reachable"
    else
      err "Connection failed" "Check: device online? sshd running? correct port/user?"
    fi
  fi

  if ask "Deploy SSH key to $name now?"; then
    deploy_ssh_key_interactive "$key" "$user" "$host" "$port" "$name"
  fi

  if ask "Add sync profiles for $name now?"; then
    while true; do
      add_device_profile "$id" || break
      ask "Add another profile?" || break
    done
  fi
}

add_device_profile() {
  local device_id="$1"
  local DEVICE_TYPE=""
  if [[ -f "$CFG/devices/${device_id}.conf" ]]; then
    # shellcheck disable=SC1090
    source "$CFG/devices/${device_id}.conf" 2>/dev/null || true
  fi

  # Offer to link an existing base profile first
  local -a base_ids=()
  mapfile -t base_ids < <(list_base_profiles 2>/dev/null)

  if [[ ${#base_ids[@]} -gt 0 ]]; then
    local mode
    mode=$(printf 'Link existing profile\nCreate new profile\n' | rofi -dmenu -p "Add sync:" \
      -mesg "Existing profiles share the local path and settings you set once" $T) || return 0
    [[ -z "$mode" ]] && return 0
    if [[ "$mode" == "Link existing profile" ]]; then
      link_profile_to_device "$device_id"
      return
    fi
  fi

  # Full "create new" form
  local name lpath rpath dir excl del

  name=$(input "Profile name" "" "What to call this sync profile (e.g. vault, music, documents)") || return 0
  [[ -z "$name" ]] && return 0
  local id; id="${device_id}-$(slug "$name")"

  lpath=$(input "Local path" "$HOME/" "Folder on THIS computer (e.g. ~/Vault, ~/Music)") || return 0
  [[ -z "$lpath" ]] && return 0
  lpath="${lpath/#\~/$HOME}"

  local default_rpath
  case "$DEVICE_TYPE" in
    termux) default_rpath="/storage/shared/" ;;
    *)      default_rpath="$HOME/" ;;
  esac
  rpath=$(input "Remote path" "$default_rpath" "Folder on REMOTE device (where files sync to/from)") || return 0
  [[ -z "$rpath" ]] && return 0

  dir=$(printf 'push\npull\nboth\n' | rofi -dmenu -p "Sync direction" \
    -mesg "push=upload to device, pull=download from device, both=bidirectional" $T) || return 0
  [[ -z "$dir" ]] && return 0

  excl=$(input "Exclude patterns" "" "Patterns to skip, comma-separated, optional — e.g. *.tmp, .cache, .git") || true
  del=false; ask "Enable --delete? (removes files on destination that don't exist in source)" && del=true || true

  cat > "$CFG/profiles/${id}.conf" <<EOF
PROFILE_NAME="$name"
LOCAL_PATH="$lpath"
REMOTE_PATH="$rpath"
DIRECTION="$dir"
RSYNC_EXCLUDE="$excl"
RSYNC_DELETE="$del"
DEVICE_ID="$device_id"
EOF

  # Offer to also save as a reusable base profile
  if ask "Save this as a reusable base profile? (lets you link it to other devices later)"; then
    local base_id; base_id=$(slug "$name")
    if [[ ! -f "$CFG/profiles/${base_id}.conf" ]]; then
      save_base_profile_config "$base_id" "$name" "$lpath" "$dir" "$excl" "$del"
      note "Base profile saved" "$name — link to other devices via Manage Device → Link Profile"
    fi
  fi

  note "Sync added" "$name  [$dir]  $lpath ↔ $rpath"
}

link_profile_to_device() {
  local device_id="$1"
  local DEVICE_NAME="" DEVICE_TYPE=""
  # shellcheck disable=SC1090
  [[ -f "$CFG/devices/${device_id}.conf" ]] && source "$CFG/devices/${device_id}.conf" 2>/dev/null || true

  local -a base_ids=()
  mapfile -t base_ids < <(list_base_profiles 2>/dev/null)
  [[ ${#base_ids[@]} -eq 0 ]] && { err "No base profiles" "Create a profile first via the Profiles menu."; return 0; }

  # Show profiles with their local path
  local -a labels=()
  for pid in "${base_ids[@]}"; do
    local PROFILE_NAME="" LOCAL_PATH="" DIRECTION="push"
    # shellcheck disable=SC1090
    source "$CFG/profiles/${pid}.conf" 2>/dev/null || continue
    labels+=("$PROFILE_NAME  [${DIRECTION}]  ${LOCAL_PATH/#$HOME/~}")
  done

  local selected
  selected=$(printf '%s\n' "${labels[@]}" | rofi -dmenu -p "Link profile:" \
    -mesg "Select a profile to link to $DEVICE_NAME — you will set the remote path for this device" $T) || return 0
  [[ -z "$selected" ]] && return 0

  local profile_id=""
  for i in "${!labels[@]}"; do
    [[ "${labels[$i]}" == "$selected" ]] && profile_id="${base_ids[$i]}" && break
  done
  [[ -z "$profile_id" ]] && return 0

  # Check if link already exists
  if [[ -f "$CFG/links/${device_id}--${profile_id}.conf" ]]; then
    local REMOTE_PATH=""
    # shellcheck disable=SC1090
    source "$CFG/links/${device_id}--${profile_id}.conf" 2>/dev/null || true
    if ! ask "Link already exists (remote: $REMOTE_PATH). Update it?"; then
      return 0
    fi
  fi

  # Load the base profile to show the local path
  local PROFILE_NAME="" LOCAL_PATH="" DIRECTION="push" RSYNC_EXCLUDE="" RSYNC_DELETE="false"
  # shellcheck disable=SC1090
  source "$CFG/profiles/${profile_id}.conf" 2>/dev/null || true

  local default_rpath
  case "$DEVICE_TYPE" in
    termux) default_rpath="/storage/shared/" ;;
    *)      default_rpath="$HOME/" ;;
  esac
  local rpath
  rpath=$(input "Remote path on $DEVICE_NAME" "$default_rpath" \
    "Local: $LOCAL_PATH  →  Where should this sync to on $DEVICE_NAME?") || return 0
  [[ -z "$rpath" ]] && return 0

  # Optional direction override
  local dir_override=""
  if ask "Override sync direction? (default: $DIRECTION from base profile)"; then
    dir_override=$(printf 'push\npull\nboth\n' | rofi -dmenu -p "Direction for $DEVICE_NAME:" \
      -filter "$DIRECTION" $T) || true
    [[ "$dir_override" == "$DIRECTION" ]] && dir_override=""
  fi

  save_link_config "$device_id" "$profile_id" "$rpath" "$dir_override"
  note "Profile linked" "$PROFILE_NAME → $DEVICE_NAME  [$rpath]"
}

unlink_profile_from_device() {
  local device_id="$1"
  local -a link_ids=()
  mapfile -t link_ids < <(list_links_for_device "$device_id" 2>/dev/null)
  [[ ${#link_ids[@]} -eq 0 ]] && { err "No linked profiles" "Nothing to unlink."; return 0; }

  local -a labels=()
  for pid in "${link_ids[@]}"; do
    local PROFILE_NAME="" LOCAL_PATH="" REMOTE_PATH=""
    # shellcheck disable=SC1090
    source "$CFG/profiles/${pid}.conf" 2>/dev/null || true
    # shellcheck disable=SC1090
    source "$CFG/links/${device_id}--${pid}.conf" 2>/dev/null || true
    labels+=("$PROFILE_NAME  $LOCAL_PATH → $REMOTE_PATH")
  done

  local selected
  selected=$(printf '%s\n' "${labels[@]}" | rofi -dmenu -p "Unlink profile:" $T) || return 0
  [[ -z "$selected" ]] && return 0

  local profile_id=""
  for i in "${!labels[@]}"; do
    [[ "${labels[$i]}" == "$selected" ]] && profile_id="${link_ids[$i]}" && break
  done
  [[ -z "$profile_id" ]] && return 0

  local PROFILE_NAME=""
  # shellcheck disable=SC1090
  source "$CFG/profiles/${profile_id}.conf" 2>/dev/null || true
  ask "Remove link '$PROFILE_NAME' from this device?" || return 0

  rm -f "$CFG/links/${device_id}--${profile_id}.conf"
  note "Link removed" "$PROFILE_NAME unlinked from this device"
}

remove_device() {
  local -a ids=(); for f in "$CFG/devices/"*.conf; do [[ -f "$f" ]] && ids+=("$(basename "$f" .conf)"); done
  [[ ${#ids[@]} -eq 0 ]] && { err "No devices" "Nothing to remove."; return 0; }
  local id; id=$(printf '%s\n' "${ids[@]}" | rofi -dmenu -p "Remove device:" $T) || return 0
  [[ -z "$id" ]] && return 0
  local DEVICE_NAME DEVICE_KEY
  # shellcheck disable=SC1090
  source "$CFG/devices/${id}.conf"
  ask "Remove '$DEVICE_NAME'? Cannot be undone." || return 0

  local -a prf_files
  mapfile -t prf_files < <(ls "$CFG/profiles/${id}-"*.conf 2>/dev/null) || true
  if [[ ${#prf_files[@]} -gt 0 ]] && ask "Also remove ${#prf_files[@]} sync profile(s) for $DEVICE_NAME?"; then
    rm -f "${prf_files[@]}"
  fi

  rm -f "$CFG/devices/${id}.conf"
  if [[ -f "${DEVICE_KEY:-}" ]] && ask "Also delete SSH key for $DEVICE_NAME?"; then
    rm -f "$DEVICE_KEY" "${DEVICE_KEY}.pub"
  fi
  note "Device removed" "$DEVICE_NAME"
}


# ── CONN TEST ──────────────────────────────────────────────────────────────────

test_conn() {
  local -a ids=(); for f in "$CFG/devices/"*.conf; do [[ -f "$f" ]] && ids+=("$(basename "$f" .conf)"); done
  [[ ${#ids[@]} -eq 0 ]] && { err "No devices" "Add a device first."; return 0; }
  local id; id=$(printf '%s\n' "${ids[@]}" | rofi -dmenu -p "Test connection:" $T) || return 0
  [[ -z "$id" ]] && return 0
  test_conn_device "$id"
}

test_conn_device() {
  local id="$1"
  local DEVICE_NAME DEVICE_HOST DEVICE_PORT DEVICE_USER DEVICE_KEY DEVICE_TYPE DEVICE_TAILSCALE
  # shellcheck disable=SC1090
  source "$CFG/devices/${id}.conf"
  local opts=(-o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=accept-new -p "$DEVICE_PORT")
  [[ -f "${DEVICE_KEY:-}" ]] && opts+=(-i "$DEVICE_KEY")
  if ssh "${opts[@]}" "${DEVICE_USER}@${DEVICE_HOST}" exit 2>/dev/null; then
    note "Connection OK" "$DEVICE_NAME ($DEVICE_HOST:$DEVICE_PORT)"
  else
    err "Connection failed" "$DEVICE_NAME — device online? sshd running?"
  fi
}

deploy_ssh_key_to_device() {
  local id="$1"
  local DEVICE_NAME DEVICE_HOST DEVICE_PORT DEVICE_USER DEVICE_KEY
  # shellcheck disable=SC1090
  source "$CFG/devices/${id}.conf"
  deploy_ssh_key_interactive "$DEVICE_KEY" "$DEVICE_USER" "$DEVICE_HOST" "$DEVICE_PORT" "$DEVICE_NAME"
}

# ── DEVICE MANAGEMENT (device-centric menu) ────────────────────────────────────

manage_device() {
  local -a ids=()
  for f in "$CFG/devices/"*.conf; do
    [[ -f "$f" ]] || continue
    ids+=("$(basename "$f" .conf)")
  done
  [[ ${#ids[@]} -eq 0 ]] && { err "No devices" "Add a device first."; return 0; }

  local id; id=$(printf '%s\n' "${ids[@]}" | rofi -dmenu -p " Select device:" $T) || return 0
  [[ -z "$id" ]] && return 0
  device_menu "$id"
}

device_menu() {
  local device_id="$1"
  local DEVICE_NAME DEVICE_HOST DEVICE_PORT DEVICE_USER DEVICE_KEY DEVICE_TYPE
  # shellcheck disable=SC1090
  source "$CFG/devices/${device_id}.conf"

  while true; do
    local -a prf_files
    mapfile -t prf_files < <(ls "$CFG/profiles/${device_id}-"*.conf 2>/dev/null) || true

    local sync_count=${#prf_files[@]}
    local header="$DEVICE_NAME  ($DEVICE_HOST)  [$sync_count syncs]"

    TITLE="$header"
    local choice; choice=$(menu \
      " View Syncs" \
      " Add Sync" \
      "  Link Profile" \
      "  Edit Sync" \
      "  Remove Sync" \
      "  Unlink Profile" \
      "  Edit Device" \
      "󰗠 Test Connection" \
      " Deploy SSH Key" \
      "󰌾 Back") || return 0

    case "$choice" in
      *"View Syncs"*)      view_device_syncs "$device_id" ;;
      *"Add Sync"*)        add_device_profile "$device_id" ;;
      *"Link Profile"*)    link_profile_to_device "$device_id" ;;
      *"Edit Sync"*)       edit_device_sync "$device_id" ;;
      *"Remove Sync"*)     remove_device_sync "$device_id" ;;
      *"Unlink Profile"*)  unlink_profile_from_device "$device_id" ;;
      *"Edit Device"*)     edit_device_config "$device_id" ;;
      *"Test Connection"*) test_conn_device "$device_id" ;;
      *"Deploy SSH Key"*)  deploy_ssh_key_to_device "$device_id" ;;
      *"Back"*)            return 0 ;;
      "")                  return 0 ;;
    esac
  done
}

view_device_syncs() {
  local device_id="$1"
  local DEVICE_NAME=""
  # shellcheck disable=SC1090
  [[ -f "$CFG/devices/${device_id}.conf" ]] && source "$CFG/devices/${device_id}.conf" 2>/dev/null || true

  local -a lines=()

  # Old-style device-specific profiles
  for f in "$CFG/profiles/${device_id}-"*.conf; do
    [[ -f "$f" ]] || continue
    local PROFILE_NAME="" LOCAL_PATH="" REMOTE_PATH="" DIRECTION=""
    # shellcheck disable=SC1090
    source "$f"
    lines+=("[sync]  $PROFILE_NAME  [$DIRECTION]  $LOCAL_PATH ↔ $REMOTE_PATH")
  done

  # New-style links
  local -a link_ids=()
  mapfile -t link_ids < <(list_links_for_device "$device_id" 2>/dev/null)
  for pid in "${link_ids[@]}"; do
    local PROFILE_NAME="" LOCAL_PATH="" REMOTE_PATH="" DIRECTION="push"
    # shellcheck disable=SC1090
    source "$CFG/profiles/${pid}.conf" 2>/dev/null || continue
    # shellcheck disable=SC1090
    source "$CFG/links/${device_id}--${pid}.conf" 2>/dev/null || continue
    lines+=("[link]  $PROFILE_NAME  [$DIRECTION]  $LOCAL_PATH ↔ $REMOTE_PATH")
  done

  if [[ ${#lines[@]} -eq 0 ]]; then
    err "No syncs" "Use Add Sync or Link Profile to set one up."
    return 0
  fi

  printf '%s\n' "${lines[@]}" | rofi -dmenu -p " Syncs for $DEVICE_NAME:" -mesg "Read-only view" $T || true
}

edit_device_sync() {
  local device_id="$1"
  local -a prf_files
  mapfile -t prf_files < <(ls "$CFG/profiles/${device_id}-"*.conf 2>/dev/null) || true
  [[ ${#prf_files[@]} -eq 0 ]] && { err "No syncs" "Add a sync first."; return 0; }

  local -a ids=(); local -a labels=()
  for f in "${prf_files[@]}"; do
    local PROFILE_NAME LOCAL_PATH DIRECTION
    # shellcheck disable=SC1090
    source "$f"
    ids+=("$f")
    labels+=("$PROFILE_NAME  [$DIRECTION]  $LOCAL_PATH")
  done

  local selected; selected=$(printf '%s\n' "${labels[@]}" | rofi -dmenu -p "  Edit sync:" $T) || return 0
  [[ -z "$selected" ]] && return 0

  local conf_file=""
  for i in "${!labels[@]}"; do
    [[ "${labels[$i]}" == "$selected" ]] && conf_file="${ids[$i]}" && break
  done
  [[ -z "$conf_file" ]] && return 0

  local PROFILE_NAME LOCAL_PATH REMOTE_PATH DIRECTION
  # shellcheck disable=SC1090
  source "$conf_file"

  local l r d
  l=$(input "Local path:" "$LOCAL_PATH")
  [[ -z "$l" ]] && l="$LOCAL_PATH"
  r=$(input "Remote path:" "$REMOTE_PATH")
  [[ -z "$r" ]] && r="$REMOTE_PATH"
  d=$(printf 'push\npull\nboth\n' | rofi -dmenu -p "Direction:" -filter "$DIRECTION" $T) || return 0
  [[ -z "$d" ]] && d="$DIRECTION"

  sed -i "s|LOCAL_PATH=.*|LOCAL_PATH=\"$l\"|; s|REMOTE_PATH=.*|REMOTE_PATH=\"$r\"|; s|DIRECTION=.*|DIRECTION=\"$d\"|" "$conf_file"
  note "Sync updated" "$PROFILE_NAME"
}

remove_device_sync() {
  local device_id="$1"
  local -a prf_files
  mapfile -t prf_files < <(ls "$CFG/profiles/${device_id}-"*.conf 2>/dev/null) || true
  [[ ${#prf_files[@]} -eq 0 ]] && { err "No syncs" "Nothing to remove."; return 0; }

  local -a ids=(); local -a labels=()
  for f in "${prf_files[@]}"; do
    local PROFILE_NAME LOCAL_PATH DIRECTION
    # shellcheck disable=SC1090
    source "$f"
    ids+=("$f")
    labels+=("$PROFILE_NAME  [$DIRECTION]  $LOCAL_PATH")
  done

  local selected; selected=$(printf '%s\n' "${labels[@]}" | rofi -dmenu -p "  Remove sync:" $T) || return 0
  [[ -z "$selected" ]] && return 0

  local conf_file=""
  for i in "${!labels[@]}"; do
    [[ "${labels[$i]}" == "$selected" ]] && conf_file="${ids[$i]}" && break
  done
  [[ -z "$conf_file" ]] && return 0

  local PROFILE_NAME
  # shellcheck disable=SC1090
  source "$conf_file"
  ask "Remove sync '$PROFILE_NAME'?" || return 0
  rm -f "$conf_file"
  note "Sync removed" "$PROFILE_NAME"
}

edit_device_config() {
  local device_id="$1"
  local DEVICE_NAME DEVICE_HOST DEVICE_PORT DEVICE_USER
  # shellcheck disable=SC1090
  source "$CFG/devices/${device_id}.conf"

  local h u p
  h=$(input "Host or IP:" "$DEVICE_HOST")
  [[ -z "$h" ]] && h="$DEVICE_HOST"
  p=$(input "SSH port:" "$DEVICE_PORT")
  [[ -z "$p" ]] && p="$DEVICE_PORT"
  u=$(input "SSH username:" "$DEVICE_USER")
  [[ -z "$u" ]] && u="$DEVICE_USER"

  sed -i "s|DEVICE_HOST=.*|DEVICE_HOST=\"$h\"|; s|DEVICE_PORT=.*|DEVICE_PORT=\"$p\"|; s|DEVICE_USER=.*|DEVICE_USER=\"$u\"|" "$CFG/devices/${device_id}.conf"
  note "Device updated" "$DEVICE_NAME"
}

# ── BASE PROFILES (reusable templates: local path + options, no remote path) ───

profiles_menu() {
  while true; do
    TITLE="Profiles"
    local choice; choice=$(menu \
      " Create Profile" \
      "  Edit Profile" \
      "  Remove Profile" \
      " List Profiles" \
      "󰌾 Back") || return 0
    case "$choice" in
      *"Create Profile"*) create_base_profile ;;
      *"Edit Profile"*)   edit_base_profile ;;
      *"Remove Profile"*) remove_base_profile ;;
      *"List Profiles"*)  list_base_profiles_view ;;
      *"Back"*)           return 0 ;;
      "")                 return 0 ;;
    esac
  done
}

create_base_profile() {
  local name lpath dir excl del

  name=$(input "Profile name" "" "Short name for this sync source (e.g. vault, music, documents)") || return 0
  [[ -z "$name" ]] && return 0
  local id; id=$(slug "$name")

  if [[ -f "$CFG/profiles/${id}.conf" ]]; then
    local existing_dev_id=""
    # shellcheck disable=SC1090
    source "$CFG/profiles/${id}.conf" 2>/dev/null || true
    if [[ -n "$existing_dev_id" ]]; then
      err "Name conflict" "A device-specific profile named '$id' already exists. Choose a different name."
      return 0
    fi
    ask "Profile '$name' already exists. Overwrite it?" || return 0
  fi

  lpath=$(input "Local path" "$HOME/" "Folder on THIS computer to sync (e.g. ~/Vault, ~/Music)") || return 0
  [[ -z "$lpath" ]] && return 0
  lpath="${lpath/#\~/$HOME}"

  dir=$(printf 'both\npush\npull\n' | rofi -dmenu -p "Default sync direction" \
    -mesg "push=upload, pull=download, both=bidirectional — can be overridden per device" $T) || return 0
  [[ -z "$dir" ]] && return 0

  excl=$(input "Exclude patterns" "" "Comma-separated, optional — e.g. .git, .cache, *.tmp") || true
  del=false; ask "Enable --delete by default? (removes files on dest not in source)" && del=true || true

  save_base_profile_config "$id" "$name" "$lpath" "$dir" "$excl" "$del"
  note "Profile created" "$name  [$dir]  $lpath — link it to devices via Manage Device → Link Profile"
}

edit_base_profile() {
  local -a base_ids=()
  mapfile -t base_ids < <(list_base_profiles 2>/dev/null)
  [[ ${#base_ids[@]} -eq 0 ]] && { err "No base profiles" "Create one first."; return 0; }

  local -a labels=()
  for pid in "${base_ids[@]}"; do
    local PROFILE_NAME="" LOCAL_PATH="" DIRECTION="push"
    # shellcheck disable=SC1090
    source "$CFG/profiles/${pid}.conf" 2>/dev/null || continue
    labels+=("$PROFILE_NAME  [$DIRECTION]  $LOCAL_PATH")
  done

  local selected; selected=$(printf '%s\n' "${labels[@]}" | rofi -dmenu -p "  Edit profile:" $T) || return 0
  [[ -z "$selected" ]] && return 0

  local profile_id=""
  for i in "${!labels[@]}"; do
    [[ "${labels[$i]}" == "$selected" ]] && profile_id="${base_ids[$i]}" && break
  done
  [[ -z "$profile_id" ]] && return 0

  local PROFILE_NAME="" LOCAL_PATH="" DIRECTION="push" RSYNC_EXCLUDE="" RSYNC_DELETE="false"
  # shellcheck disable=SC1090
  source "$CFG/profiles/${profile_id}.conf" 2>/dev/null || true

  local l d e
  l=$(input "Local path:" "$LOCAL_PATH")
  [[ -z "$l" ]] && l="$LOCAL_PATH"
  l="${l/#\~/$HOME}"
  d=$(printf 'both\npush\npull\n' | rofi -dmenu -p "Direction:" -filter "$DIRECTION" $T) || return 0
  [[ -z "$d" ]] && d="$DIRECTION"
  e=$(input "Exclude patterns:" "$RSYNC_EXCLUDE") || true
  [[ -z "$e" ]] && e="$RSYNC_EXCLUDE"

  save_base_profile_config "$profile_id" "$PROFILE_NAME" "$l" "$d" "$e" "$RSYNC_DELETE"
  note "Profile updated" "$PROFILE_NAME"
}

remove_base_profile() {
  local -a base_ids=()
  mapfile -t base_ids < <(list_base_profiles 2>/dev/null)
  [[ ${#base_ids[@]} -eq 0 ]] && { err "No base profiles" "Nothing to remove."; return 0; }

  local -a labels=()
  for pid in "${base_ids[@]}"; do
    local PROFILE_NAME="" LOCAL_PATH="" DIRECTION="push"
    # shellcheck disable=SC1090
    source "$CFG/profiles/${pid}.conf" 2>/dev/null || continue
    labels+=("$PROFILE_NAME  [$DIRECTION]  $LOCAL_PATH")
  done

  local selected; selected=$(printf '%s\n' "${labels[@]}" | rofi -dmenu -p "  Remove profile:" $T) || return 0
  [[ -z "$selected" ]] && return 0

  local profile_id=""
  for i in "${!labels[@]}"; do
    [[ "${labels[$i]}" == "$selected" ]] && profile_id="${base_ids[$i]}" && break
  done
  [[ -z "$profile_id" ]] && return 0

  local PROFILE_NAME=""
  # shellcheck disable=SC1090
  source "$CFG/profiles/${profile_id}.conf" 2>/dev/null || true

  # Warn if any links reference this profile
  local -a linked_devs=()
  for f in "$CFG/links/"*"--${profile_id}.conf"; do
    [[ -f "$f" ]] && linked_devs+=("$(basename "$f" ".conf" | sed "s/--${profile_id}//")")
  done
  if [[ ${#linked_devs[@]} -gt 0 ]]; then
    local msg="${#linked_devs[@]} device(s) still linked: ${linked_devs[*]}. Links will break."
    ask "Remove '$PROFILE_NAME'? $msg" || return 0
  else
    ask "Remove base profile '$PROFILE_NAME'? Cannot be undone." || return 0
  fi

  rm -f "$CFG/profiles/${profile_id}.conf"
  note "Profile removed" "$PROFILE_NAME"
}

list_base_profiles_view() {
  local -a base_ids=()
  mapfile -t base_ids < <(list_base_profiles 2>/dev/null)
  [[ ${#base_ids[@]} -eq 0 ]] && { err "No base profiles" "Create one first."; return 0; }

  local -a lines=()
  for pid in "${base_ids[@]}"; do
    local PROFILE_NAME="" LOCAL_PATH="" DIRECTION="push"
    # shellcheck disable=SC1090
    source "$CFG/profiles/${pid}.conf" 2>/dev/null || continue
    # Count links for this profile
    local link_count=0
    for f in "$CFG/links/"*"--${pid}.conf"; do [[ -f "$f" ]] && ((link_count++)) || true; done
    lines+=("$PROFILE_NAME  [$DIRECTION]  $LOCAL_PATH  (linked to $link_count device(s))")
  done

  printf '%s\n' "${lines[@]}" | rofi -dmenu -p " Base Profiles:" $T || true
}

# ── SHARED PROFILES (global profiles without device scope) ─────────────────────

get_shared_profile_files() {
  for f in "$CFG/profiles/"*.conf; do
    [[ -f "$f" ]] || continue
    local DEVICE_ID=""
    # shellcheck disable=SC1090
    source "$f" 2>/dev/null || continue
    [[ -z "$DEVICE_ID" ]] && echo "$f"
  done
}

shared_profiles_menu() {
  while true; do
    TITLE="Shared Profiles"
    local choice; choice=$(menu \
      " Add Shared Profile" \
      "  Edit Shared Profile" \
      "  Remove Shared Profile" \
      " List Shared Profiles" \
      "󰌾 Back") || return 0

    case "$choice" in
      *"Add Shared"*)    add_shared_profile ;;
      *"Edit Shared"*)   edit_shared_profile ;;
      *"Remove Shared"*) remove_shared_profile ;;
      *"List Shared"*)   list_shared_profiles ;;
      *"Back"*)          return 0 ;;
      "")                return 0 ;;
    esac
  done
}

add_shared_profile() {
  local name lpath rpath dir excl del

  name=$(input "Profile name (e.g. notes, keepass):" "") || return 0
  [[ -z "$name" ]] && return 0
  local id; id=$(slug "$name")

  lpath=$(input "Local path:" "$HOME/") || return 0
  [[ -z "$lpath" ]] && return 0
  lpath="${lpath/#\~/$HOME}"

  rpath=$(input "Remote path:") || return 0
  [[ -z "$rpath" ]] && return 0

  dir=$(printf 'push\npull\nboth\n' | rofi -dmenu -p "Direction:" $T) || return 0
  [[ -z "$dir" ]] && return 0

  excl=$(input "Exclude patterns (comma-sep, optional):" "") || true

  del=false; ask "Enable --delete? (removes files on dest not in source)" && del=true || true

  cat > "$CFG/profiles/${id}.conf" <<EOF
PROFILE_NAME="$name"
LOCAL_PATH="$lpath"
REMOTE_PATH="$rpath"
DIRECTION="$dir"
RSYNC_EXCLUDE="$excl"
RSYNC_DELETE="$del"
EOF
  note "Profile saved" "$name  [$dir]  $lpath ↔ $rpath"
}

edit_shared_profile() {
  local -a files; mapfile -t files < <(get_shared_profile_files)
  [[ ${#files[@]} -eq 0 ]] && { err "No shared profiles" "Add one first."; return 0; }

  local -a ids=(); local -a labels=()
  for f in "${files[@]}"; do
    local PROFILE_NAME LOCAL_PATH REMOTE_PATH DIRECTION
    # shellcheck disable=SC1090
    source "$f"
    ids+=("$f")
    labels+=("$PROFILE_NAME  [$DIRECTION]  $LOCAL_PATH → $REMOTE_PATH")
  done

  local selected; selected=$(printf '%s\n' "${labels[@]}" | rofi -dmenu -p "  Edit shared profile:" $T) || return 0
  [[ -z "$selected" ]] && return 0

  local conf_file=""
  for i in "${!labels[@]}"; do
    [[ "${labels[$i]}" == "$selected" ]] && conf_file="${ids[$i]}" && break
  done
  [[ -z "$conf_file" ]] && return 0

  local PROFILE_NAME LOCAL_PATH REMOTE_PATH DIRECTION
  # shellcheck disable=SC1090
  source "$conf_file"

  local l r d
  l=$(input "Local path:" "$LOCAL_PATH")
  [[ -z "$l" ]] && l="$LOCAL_PATH"
  r=$(input "Remote path:" "$REMOTE_PATH")
  [[ -z "$r" ]] && r="$REMOTE_PATH"
  d=$(printf 'push\npull\nboth\n' | rofi -dmenu -p "Direction:" -filter "$DIRECTION" $T) || return 0
  [[ -z "$d" ]] && d="$DIRECTION"

  sed -i "s|LOCAL_PATH=.*|LOCAL_PATH=\"$l\"|; s|REMOTE_PATH=.*|REMOTE_PATH=\"$r\"|; s|DIRECTION=.*|DIRECTION=\"$d\"|" "$conf_file"
  note "Profile updated" "$PROFILE_NAME"
}

remove_shared_profile() {
  local -a files; mapfile -t files < <(get_shared_profile_files)
  [[ ${#files[@]} -eq 0 ]] && { err "No shared profiles" "Nothing to remove."; return 0; }

  local -a ids=(); local -a labels=()
  for f in "${files[@]}"; do
    local PROFILE_NAME LOCAL_PATH REMOTE_PATH DIRECTION
    # shellcheck disable=SC1090
    source "$f"
    ids+=("$f")
    labels+=("$PROFILE_NAME  [$DIRECTION]  $LOCAL_PATH → $REMOTE_PATH")
  done

  local selected; selected=$(printf '%s\n' "${labels[@]}" | rofi -dmenu -p "  Remove shared profile:" $T) || return 0
  [[ -z "$selected" ]] && return 0

  local conf_file=""
  for i in "${!labels[@]}"; do
    [[ "${labels[$i]}" == "$selected" ]] && conf_file="${ids[$i]}" && break
  done
  [[ -z "$conf_file" ]] && return 0

  local PROFILE_NAME
  # shellcheck disable=SC1090
  source "$conf_file"
  ask "Remove shared profile '$PROFILE_NAME'?" || return 0
  rm -f "$conf_file"
  note "Profile removed" "$PROFILE_NAME"
}

list_shared_profiles() {
  local -a files; mapfile -t files < <(get_shared_profile_files)
  [[ ${#files[@]} -eq 0 ]] && { err "No shared profiles" "Add one first."; return 0; }

  local -a lines=()
  for f in "${files[@]}"; do
    local PROFILE_NAME LOCAL_PATH REMOTE_PATH DIRECTION
    # shellcheck disable=SC1090
    source "$f"
    lines+=("$PROFILE_NAME  [$DIRECTION]  $LOCAL_PATH → $REMOTE_PATH")
  done

  printf '%s\n' "${lines[@]}" | rofi -dmenu -p " Shared Profiles:" $T || true
}

