#!/bin/bash
set -euo pipefail

if [[ ! -t 0 ]]; then
  if command -v ptyxis &>/dev/null; then
    exec ptyxis -- bash -c "\"$0\""
  elif command -v foot &>/dev/null; then
    exec foot bash -c "\"$0\""
  elif command -v kitty &>/dev/null; then
    exec kitty bash -c "\"$0\""
  elif command -v alacritty &>/dev/null; then
    exec alacritty -e bash -c "\"$0\""
  elif command -v wezterm &>/dev/null; then
    exec wezterm start -- bash -c "\"$0\""
  elif command -v gnome-terminal &>/dev/null; then
    exec gnome-terminal -- bash -c "\"$0\""
  else
    notify-send "Error" "No supported terminal emulator found."
    exit 1
  fi
fi

if ! command -v fzf &>/dev/null; then
  echo "Error: fzf is required. Install it with: brew install fzf"
  read -rn1 -p "Press any key to exit..."
  exit 1
fi

BINDINGS_FILE="$HOME/.config/sway/bindings"
USER_BINDINGS_FILE="$HOME/.config/sway/user-bindings"

extract_sway_bindings() {
  grep -h "^[[:space:]]*bindsym" "$BINDINGS_FILE" "$USER_BINDINGS_FILE" 2>/dev/null |
    sed -r \
      -e 's/^[[:space:]]*bindsym[[:space:]]+//' \
      -e 's/--to-code//' \
      -e 's/--locked//' \
      -e 's/--no-warn//' \
      -e 's/\$mod/SUPER/g' \
      -e 's/exec[[:space:]]+//' \
      -e 's,~/.local/share/omarchy/bin/,,g' \
      -e 's,~/.local/share/omablue/bin/,,g'
}

parse_bindings() {
  awk '{
    match($0, /[[:space:]]/);
    key_combo = substr($0, 1, RSTART-1);
    action = substr($0, RSTART+1);
    gsub(/^[ \t]+|[ \t]+$/, "", action);
    if (action != "") {
      printf "%-30s  →  %s\n", key_combo, action;
    }
  }'
}

prioritize_entries() {
  awk -F '→' '
    {
      line = $0
      prio = 50
      if (line ~ /terminal|foot/)       prio = 0
      if (line ~ /browser|firefox/)     prio = 1
      if (line ~ /nautilus|thunar/)     prio = 2
      if (line ~ /menu|fzf|wofi/)       prio = 4
      if (line ~ /screenshot|grim/)     prio = 15
      if (line ~ /scratchpad/)          prio = 25
      printf "%d\t%s\n", prio, line
    }' | sort -k1,1n -k2,2 | cut -f2-
}

extract_sway_bindings | sort -u | parse_bindings | prioritize_entries | fzf \
  --prompt="  Keybindings > " \
  --height=80% \
  --border=rounded \
  --no-multi \
  --header="Fuzzy filter keybindings — Enter/Esc to close" \
  2>/dev/null || true
